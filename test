    // 1. Admin Function to send the message
async function postAnnouncement() {
    const text = document.getElementById('admin-announcement').value;
    if (!text) return;

    // Verify admin status
    const { data } = await _supabase.from('leaderboard').select('admin').eq('username', chatName).single();
    if (!data || !data.admin) return alert("Unauthorized");

    const { error } = await _supabase.from('announcements').insert([{ text: text }]);
    
    if (!error) {
        document.getElementById('admin-announcement').value = "";
        alert("Broadcast sent!");
    }
}

// 2. Logic to show the announcement to everyone
function showAnnouncement(text) {
    const bar = document.getElementById('announcement-bar');
    const display = document.getElementById('announcement-text');
    
    display.innerText = "📣 ANNOUNCEMENT: " + text;
    bar.style.display = 'block';

    // Auto-hide after 15 seconds
    setTimeout(() => {
        bar.style.display = 'none';
    }, 15000);
}
    
    async function prestige() {
    if (energy < 1000000000) return alert("You need at least 1 Billion Mass to Weigh In!");

    const bonus = Math.floor(Math.log10(energy / 1000000000)) + 1;
    
    if (confirm(`Prestige now? You will lose all your current Mass and Upgrades, but you will gain ${bonus} Golden Torta(s). Each Golden Torta gives a permanent +10% boost to ALL production!`)) {
        
        // 1. Add the permanent currency
        goldenTortas += bonus;

        // 2. Reset game state
        energy = 0;
        clickPower = 1;
        cps = 0;
        totalClicks = 0;

        // 3. Reset upgrades to initial state
        upgrades = initialUpgrades.map(u => ({...u, count: 0}));

        // 4. Update the Shop UI to show base costs again
        initShop();
        
        // 5. Save to cloud and update screen
        await cloudSave();
        updateUI();
        
        alert("You have Weighed In! Your new Golden Tortas have increased your power permanently.");
    }
}
    
    async function changeName() {
    let newName = prompt("Enter your new username:", chatName || "");
    
    // 1. Validation
    if (!newName) return;
    newName = newName.trim();
    if (newName === chatName) return;
    if (newName.length < 2 || newName.length > 15) return alert("Name must be 2-15 characters.");

    try {
        // 2. Update the Database (Leaderboard)
        // This moves your score and admin status to the new name
        const { error } = await _supabase
            .from('leaderboard')
            .update({ username: newName })
            .eq('username', chatName);

        if (error) {
            console.error("DB Error:", error);
            return alert("That name might be taken or the database is busy.");
        }

        // 3. Update Local Storage
        chatName = newName;
        localStorage.setItem('chat_name', chatName);
        
        // 4. Force a Save and Reload
        // We reload so the game recognizes the new name for Admin checks
        await cloudSave(); 
        alert("Name updated! Refreshing to sync...");
        location.reload();

    } catch (err) {
        console.error("Change Name Failed:", err);
        alert("Something went wrong changing your name.");
    }
}
    
    async function openAdmin() {
    if (!chatName) return alert("Please set a username first.");

    // Check if the current user is actually an admin in the database
    const { data, error } = await _supabase
        .from('leaderboard')
        .select('admin')
        .eq('username', chatName)
        .single();

    if (data && data.admin === true) {
        document.getElementById('admin-panel').style.display = 'block';
    } else {
        console.warn("Unauthorized admin access attempt by:", chatName);
        alert("Access Denied: You do not have administrator privileges.");
    }
}

async function triggerEvent(type) {
    // Re-verify admin status before letting the database call go through
    const { data } = await _supabase.from('leaderboard').select('admin').eq('username', chatName).single();
    if (!data || !data.admin) return alert("Nice try!");

    const expiresAt = new Date(Date.now() + 5 * 60000).toISOString();
    await _supabase.from('game_events').insert([{ event_type: type, expires_at: expiresAt }]);
    document.getElementById('admin-panel').style.display = 'none';
}

let rainInterval = null;

function handleNewEvent(event) {
    if (eventTimer) clearInterval(eventTimer);
    if (rainInterval) clearInterval(rainInterval); // Clear existing rain
    
    const oldNotice = document.getElementById('event-notice');
    if (oldNotice) oldNotice.remove();

    const mainImg = document.getElementById('lincoln-main');
    const DEFAULT_IMG = "IMG_0668.jpg"; 
    const STORM_IMG = "IMG_0682.jpg"; 

    const expiry = new Date(event.expires_at.replace(' ', 'T')).getTime();
    const notice = document.createElement('div');
    notice.id = "event-notice";
    notice.style = "position:fixed; top:10%; left:50%; transform:translateX(-50%); color:black; padding:15px 30px; border-radius:50px; font-weight:bold; z-index:10000; box-shadow:0 0 20px rgba(0,0,0,0.5); text-align:center; pointer-events:none;";
    document.body.appendChild(notice);

    eventTimer = setInterval(() => {
        const now = new Date().getTime();
        const timeLeft = expiry - now;

        if (timeLeft <= 0) {
            eventMultiplier = 1;
            currentEvent = null;
            mainImg.src = DEFAULT_IMG;
            mainImg.style.filter = "none";
            document.body.style.boxShadow = "none";
            notice.remove();
            clearInterval(eventTimer);
            if (rainInterval) clearInterval(rainInterval); // Stop rain
            return;
        }

        const seconds = Math.ceil(timeLeft / 1000);
        currentEvent = event.event_type;

        if (currentEvent === 'storm') {
            eventMultiplier = 5;
            notice.style.background = "#00d2ff";
            notice.innerText = `⚡ STORM! 5X CLICK (${seconds}s)`;
            
            // Start raining if not already started
            if (!rainInterval) {
                rainInterval = setInterval(createRaindrop, 50);
            }

            if (!mainImg.src.includes(STORM_IMG)) {
                mainImg.src = STORM_IMG;
                mainImg.style.filter = "drop-shadow(0 0 20px #00d2ff) brightness(1.2)";
            }
        } 
        else if (currentEvent === 'feast') {
            if (rainInterval) { clearInterval(rainInterval); rainInterval = null; }
            eventMultiplier = 2;
            notice.style.background = "var(--gold)";
            notice.innerText = `🔥 FEAST! 2X TOTAL MASS (${seconds}s)`;
            mainImg.style.filter = "drop-shadow(0 0 25px var(--gold))";
        } 
        else if (currentEvent === 'low_carb') {
            if (rainInterval) { clearInterval(rainInterval); rainInterval = null; }
            eventMultiplier = 0.5;
            notice.style.background = "#ff4757";
            notice.style.color = "white";
            notice.innerText = `🥗 LOW CARB! 0.5X TOTAL MASS (${seconds}s)`;
            mainImg.style.filter = "grayscale(0.6) opacity(0.8)";
        }
    }, 1000);
}

// Helper function to generate raindrops
function createRaindrop() {
    const drop = document.createElement('div');
    drop.className = 'raindrop';
    drop.style.left = Math.random() * 100 + 'vw';
    drop.style.animationDuration = (Math.random() * 0.5 + 0.5) + 's'; // Fast rain
    document.body.appendChild(drop);
    
    // Remove drop from DOM after it falls
    setTimeout(() => { drop.remove(); }, 1000);
}

document.getElementById('lincoln-main').addEventListener('click', (e) => {
    let val = (clickPower * (1 + (goldenTortas * 0.1))) * eventMultiplier;
    energy += val; totalClicks++;
    showParticle(e.clientX, e.clientY, `+${val.toFixed(1)}`);
    updateUI();
});
      
setInterval(() => { 
    let boostedCPS = (cps * (1 + (goldenTortas * 0.1))) * (currentEvent === 'storm' ? 1 : eventMultiplier);
    energy += (boostedCPS / 10); updateUI(); 
}, 100);

function updateUI() {
    document.getElementById('score-text').innerText = Math.floor(energy).toLocaleString();
    document.getElementById('stat-click').innerText = ((clickPower * (1 + (goldenTortas * 0.1))) * eventMultiplier).toFixed(1);
    document.getElementById('stat-cps').innerText = ((cps * (1 + (goldenTortas * 0.1))) * (currentEvent === 'storm' ? 1 : eventMultiplier)).toFixed(1);
    document.getElementById('stat-prestige').innerText = goldenTortas;
    document.getElementById('prestige-btn').style.display = energy >= 1000000000 ? 'block' : 'none';
    
    upgrades.forEach(u => {
        const btn = document.getElementById(`up-${u.id}`);
        if (btn) {
            btn.disabled = energy < u.cost;
            energy >= u.cost ? btn.classList.add('can-afford') : btn.classList.remove('can-afford');
            document.getElementById(`cost-${u.id}`).innerText = u.cost.toLocaleString() + " Mass";
            document.getElementById(`count-${u.id}`).innerText = u.count;
        }
    });

    const body = document.body; const label = document.getElementById('env-label');
    if (energy < 100000) { body.className = 'bg-kitchen'; label.innerText = "LOCATION: THE KITCHEN"; }
    else if (energy < 10000000) { body.className = 'bg-buffet'; label.innerText = "LOCATION: INFINITE BUFFET"; }
    else if (energy < 1000000000) { body.className = 'bg-factory'; label.innerText = "LOCATION: TORTA FACTORY"; }
    else { body.className = 'bg-space'; label.innerText = "LOCATION: OUTER SPACE"; }
}

async function cloudSave() {
    if (!chatName || chatName === "Anonymous") return;

    // Use Math.round to ensure we only send clean integers to Supabase
    const savedClicks = Math.round(energy);
    const savedTortas = Math.round(goldenTortas);

    const { error } = await _supabase
        .from('leaderboard')
        .upsert({ 
            username: chatName, 
            clicks: savedClicks, 
            golden_tortas: savedTortas 
        }, { onConflict: 'username' });

    if (error) {
        console.error("Sync Error:", error.message);
        document.getElementById('sync-status').innerText = "Sync Error!";
        document.getElementById('sync-status').style.color = "#ff4757";
    } else {
        document.getElementById('sync-status').innerText = "Sync Active";
        document.getElementById('sync-status').style.color = "#777";
    }
}
    
async function cloudLoad() {
    // 1. Try to load from Supabase (Cloud)
    if (chatName && chatName !== "Anonymous") {
        const { data, error } = await _supabase
            .from('leaderboard')
            .select('clicks, golden_tortas')
            .eq('username', chatName)
            .single();

        if (data && !error) {
            // Priority: Use Cloud Data
            energy = data.clicks || 0;
            goldenTortas = data.golden_tortas || 0;
            console.log("Cloud save loaded for:", chatName);
        }
    }

    // 2. Load Upgrades and Stats from Local Storage 
    // (We keep upgrades local for now to save database space)
    const local = localStorage.getItem('lincoln_local_save');
    if (local) {
        const d = JSON.parse(local);
        
        // Only use local energy if cloud failed
        if (!energy) energy = d.energy || 0; 
        
        clickPower = d.clickPower || 1; 
        cps = d.cps || 0; 
        totalClicks = d.totalClicks || 0;
        
        d.upgrades?.forEach((savedU, i) => { 
            if(upgrades[i]) { 
                upgrades[i].count = savedU.count; 
                upgrades[i].cost = savedU.cost; 
            } 
        });
    }

    // 3. Refresh the screen
    updateUI();
}


   localStorage.setItem('lincoln_local_save', JSON.stringify({
    energy: energy,
    clickPower: clickPower,
    cps: cps,
    goldenTortas: goldenTortas,
    totalClicks: totalClicks,
    upgrades: upgrades
})); 
    
    // Admin Logic
async function adminAction(type) {
    const target = document.getElementById('admin-target-user').value;
    const val = document.getElementById('admin-value').value;
    if (!target) return alert("Enter target");
    if (type === 'mass') {
        if (target === chatName) { energy += parseFloat(val); updateUI(); }
        await _supabase.from('leaderboard').update({ clicks: parseFloat(val) }).eq('username', target);
    }
}

function initShop() {
    const shop = document.getElementById('shop'); shop.innerHTML = '';
    upgrades.forEach(u => {
        const btn = document.createElement('button');
        btn.className = 'upgrade'; btn.id = `up-${u.id}`;
        btn.onclick = () => buyUpgrade(u.id);
        btn.innerHTML = `<div class="u-info"><span class="u-name">${u.name}</span><span class="u-desc">${u.desc}</span><span class="u-cost" id="cost-${u.id}">${u.cost.toLocaleString()} Mass</span></div><div class="u-count" id="count-${u.id}">${u.count}</div>`;
        shop.appendChild(btn);
    });
}

function buyUpgrade(id) {
    const u = upgrades[id];
    if (energy >= u.cost) {
        energy -= u.cost; u.count++;
        if (u.type === "click") clickPower += u.power; else cps += u.power;
        u.cost = Math.ceil(u.cost * 1.35); updateUI(); cloudSave();
    }
}

function toggleChat() {
    const b = document.getElementById('chat-box');
    if (b.style.display === 'flex') { b.style.display = 'none'; return; }
    if (!chatName) {
        let input = prompt("Enter Username:");
        if (!input) return;
        chatName = input.trim();
        localStorage.setItem('chat_name', chatName);
    }
    b.style.display = 'flex'; fetchMessages();
}

async function fetchMessages() {
    const { data } = await _supabase.from('global_chat').select('*').order('created_at', { ascending: false }).limit(30);
    if (data) {
        document.getElementById('chat-messages').innerHTML = data.reverse().map(m => `
            <div class="msg ${m.username === currentKing ? 'king-msg' : ''}"><b>${m.username}:</b> ${m.message}</div>`).join('');
        const c = document.getElementById('chat-messages'); c.scrollTop = c.scrollHeight;
    }
}

async function sendChat(emoteMsg = null) {
    if (!chatName) return;
    const input = document.getElementById('chat-msg-input');
    const message = emoteMsg || input.value;
    if (!message) return;
    await _supabase.from('global_chat').insert([{ username: chatName, message: message }]);
    input.value = ""; fetchMessages();
}

function sendEmote(char) { sendChat(char); }

async function fetchLeaderboard() {
    const { data } = await _supabase.from('leaderboard').select('username, clicks, golden_tortas').order('clicks', { ascending: false }).limit(10);
    if (data) {
        document.getElementById('lb-content').innerHTML = data.map((u, i) => `
            <div class="lb-row"><span><span class="lb-rank">#${i+1}</span> ${u.username}</span><span>${Math.floor(u.clicks).toLocaleString()} <small>(${u.golden_tortas} GT)</small></span></div>`).join('');
        if (data[0]) { currentKing = data[0].username; document.getElementById('king-display').innerText = `👑 King: ${currentKing}`; }
    }
}

function showParticle(x, y, text) {
    const p = document.createElement('div'); p.className = 'particle'; p.innerText = text;
    p.style.left = x + 'px'; p.style.top = y + 'px';
    document.body.appendChild(p); setTimeout(() => p.remove(), 800);
}

function resetGame() { if (confirm("Reset everything?")) { localStorage.clear(); location.reload(); } }

async function startGame() {
    initShop(); 
    cloudLoad();

    // 1. Listen for Game Events (Storms, Feasts, etc.)
    _supabase.channel('game-events')
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'game_events' }, (p) => handleNewEvent(p.new))
        .subscribe();

    // 2. Listen for Admin Announcements (The new system)
    _supabase.channel('announcements-realtime')
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'announcements' }, (payload) => {
            showAnnouncement(payload.new.text);
        })
        .subscribe();

    // Check for active events on startup
    const { data } = await _supabase.from('game_events')
        .select('*')
        .gt('expires_at', new Date().toISOString())
        .order('created_at', { ascending: false })
        .limit(1);
    
    if (data && data[0]) handleNewEvent(data[0]);

    // Background Loops
    setInterval(cloudSave, 20000); 
    setInterval(fetchLeaderboard, 15000);
    setInterval(() => { 
        if(document.getElementById('chat-box').style.display === 'flex') fetchMessages(); 
    }, 5000);

    fetchLeaderboard();
}

startGame();
</script>
